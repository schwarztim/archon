{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "copilot-sdd learning",
  "description": "A captured learning from a development session",
  "type": "object",
  "required": ["id", "type", "created_at", "summary", "detail"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["pitfall", "pattern", "decision", "fix"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "source_phase": { "type": "string" },
    "severity": {
      "type": "string",
      "enum": ["critical", "important", "useful"],
      "default": "useful"
    },
    "summary": { "type": "string", "maxLength": 200 },
    "detail": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
