# ──────────────────────────────────────────────────────────────────────
# Archon Platform — Environment Variables (.env.example)
# ──────────────────────────────────────────────────────────────────────
# Copy to .env and fill in values before running `docker compose up`.
# Variables prefixed ARCHON_ are read by the backend via pydantic-settings.
# Variables in ALL_CAPS without prefix are consumed directly by clients
# (vault CLI, postgres, etc).
#
# ⚠ DEV ONLY values are clearly marked. Production deployments MUST
# override every value tagged DEV ONLY before exposing the stack to a
# trusted network.
# ──────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────
POSTGRES_USER=archon
POSTGRES_PASSWORD=archon                          # DEV ONLY
POSTGRES_DB=archon
ARCHON_DATABASE_URL=postgresql+asyncpg://archon:archon@postgres:5432/archon

# ── Redis ────────────────────────────────────────────────────────────
ARCHON_REDIS_URL=redis://redis:6379/0

# ── JWT / Auth ───────────────────────────────────────────────────────
ARCHON_JWT_SECRET=dev-secret-key-for-testing      # DEV ONLY — rotate via Vault in prod
ARCHON_JWT_ALGORITHM=HS256
ARCHON_AUTH_DEV_MODE=true                         # DEV ONLY — disables real OIDC

# ── Keycloak ─────────────────────────────────────────────────────────
ARCHON_KEYCLOAK_URL=http://keycloak:8080/auth/realms/archon
ARCHON_KEYCLOAK_CLIENT_ID=archon-app

# ── Vault ────────────────────────────────────────────────────────────
# DEV ONLY — root token only used by the local docker-compose vault
# service running with `-dev`. Production deployments MUST:
#   1. Run Vault in production (non-dev) mode with sealed storage.
#   2. Rotate the root token immediately after init and store it
#      offline (Shamir / KMS-wrapped).
#   3. Issue scoped tokens via AppRole for backend + worker.
#   4. Replace VAULT_TOKEN with a secrets-manager injected value.
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=archon-dev-root                       # DEV ONLY
ARCHON_VAULT_ADDR=http://vault:8200
ARCHON_VAULT_TOKEN=archon-dev-root                # DEV ONLY
ARCHON_VAULT_NAMESPACE=archon
ARCHON_VAULT_MOUNT_POINT=secret
ARCHON_VAULT_ENABLED=true

# ── Logging / Debug ─────────────────────────────────────────────────
ARCHON_DEBUG=true                                 # DEV ONLY
ARCHON_LOG_LEVEL=DEBUG

# ── Grafana ──────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin                  # DEV ONLY
GF_USERS_ALLOW_SIGN_UP=false

# ── Feature Flags ───────────────────────────────────────────────────
ARCHON_FEATURE_DLP_ENABLED=true
ARCHON_FEATURE_COST_TRACKING=true
ARCHON_FEATURE_MCP_SECURITY=true
ARCHON_FEATURE_A2A_ENABLED=true

# ── Worker ──────────────────────────────────────────────────────────
ARCHON_WORKER_CONCURRENCY=4
ARCHON_WORKER_SCAN_INTERVAL=300

# ── LLM ──────────────────────────────────────────────────────────────
# DEV: leave LLM_STUB_MODE=true to skip live API calls. Set to false
# only when host env supplies real API keys (preferably via Vault).
LLM_STUB_MODE=true
# Real keys live in Vault at secret/archon/llm — do NOT put them here.
# The placeholders below are for shell interpolation only; populate them
# from a secrets manager, not by editing this file.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
