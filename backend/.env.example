# Archon Backend — Environment Variables
# Copy to .env and fill in values.
# All config vars use the ARCHON_ prefix (see app/config.py).

# Database (PostgreSQL + asyncpg)
ARCHON_DATABASE_URL=postgresql+asyncpg://archon:archon@localhost:5432/archon

# Redis
ARCHON_REDIS_URL=redis://localhost:6379/0

# App
ARCHON_DEBUG=true
ARCHON_LOG_LEVEL=DEBUG
ARCHON_CORS_ORIGINS=["http://localhost:3000"]
