    "typescript": "~5.7.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.2.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "minimatch": ">=10.2.1",
    "ajv": ">=8.18.0",
